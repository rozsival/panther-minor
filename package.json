{
  "name": "@rozsival/panther-minor",
  "version": "0.0.0",
  "private": true,
  "description": "The AI Workstation Setup",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rozsival/panther-minor.git"
  },
  "type": "module",
  "scripts": {
    "build:cli": "cd bin && bashly generate && bashly add completions --force",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "fix:unsafe": "ultracite fix --unsafe",
    "postinstall": "is-ci || lefthook install",
    "test": "node --test \"**/*.test.js\""
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "is-ci": "4.1.0",
    "lefthook": "2.1.4",
    "ultracite": "7.3.2"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.x"
  }
}
