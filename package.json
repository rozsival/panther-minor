{
  "name": "@rozsival/panther-minor",
  "version": "1.1.1",
  "private": true,
  "description": "The AI Workstation Setup",
  "repository": {
    "type": "git",
    "url": "https://github.com/rozsival/panther-minor.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:cli": "cd bin && rm src/lib/send_completions.sh && bashly add completions && bashly generate",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "fix:unsafe": "ultracite fix --unsafe",
    "format": "prettier --check --write .",
    "postinstall": "is-ci || lefthook install",
    "test": "node --test \"**/*.test.js\""
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "21.0.0",
    "@commitlint/config-conventional": "21.0.0",
    "@types/node": "24.12.3",
    "is-ci": "4.1.0",
    "lefthook": "2.1.6",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-toml": "2.0.6",
    "typescript": "6.0.3",
    "ultracite": "7.7.0"
  },
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": "24.x"
  }
}
