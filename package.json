{
	"name": "@rozsival/panther-minor",
	"version": "0.0.0",
	"private": true,
	"description": "The AI Workstation Setup",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/rozsival/panther-minor.git"
	},
	"type": "module",
	"scripts": {
		"check": "biome check --write --unsafe .",
		"format": "biome format --write .",
