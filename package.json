{
  "name": "@rozsival/panther-minor",
  "version": "0.0.0",
  "private": true,
  "description": "The AI Workstation Setup",
  "repository": {
    "type": "git",
    "url": "https://github.com/rozsival/panther-minor.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:cli": "cd bin && rm src/lib/send_completions.sh && bashly add completions && bashly generate",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "fix:unsafe": "ultracite fix --unsafe",
    "format": "prettier --check --write \"**/*.{md,toml,yaml,yml}\" \"package.json\"",
    "postinstall": "is-ci || lefthook install",
    "test": "node --test \"**/*.test.js\""
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "is-ci": "4.1.0",
    "lefthook": "2.1.4",
    "prettier": "3.8.1",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-toml": "2.0.6",
    "ultracite": "7.4.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x"
  }
}
