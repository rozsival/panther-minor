{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "provider": {
    "panther-minor": {
      "name": "Panther Minor",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://<domain>:8000/v1",
        "chunkTimeout": 600000,
        "setCacheKey": true,
        "timeout": 600000
      },
      "models": {
        "panther-coder": {
          "name": "panther-coder",
          "limit": {
            "context": 131072,
            "output": 4096
          }
        },
        "panther-coder-next": {
          "name": "panther-coder-next",
          "limit": {
            "context": 131072,
            "output": 6144
          }
        },
        "panther-coder-large": {
          "name": "panther-coder-large",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  }
}
