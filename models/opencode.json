{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "provider": {
    "panther-minor": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Panther Minor",
      "options": {
        "baseURL": "https://panther.<domain>:8000/v1"
      },
      "models": {
        "panther-coder": {
          "name": "panther-coder",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "panther-coder-next": {
          "name": "panther-coder-next",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  }
}
