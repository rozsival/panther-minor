#!/usr/bin/env bash
# -- Remove previously downloaded model from the local directory --------------
set -euo pipefail
source "$(dirname "$0")/common.sh"

MODEL=${1:-}

if [[ -z "$MODEL" ]]; then
  echo "Usage: $0 <model-name>"
  exit 1
fi

assert_supported_model "$MODEL"

# Remove the model file
if [[ -f "$HF_DIR/$MODEL.gguf" ]]; then
  rm "$HF_DIR/$MODEL.gguf"
elses
  echo "Error: Model '$MODEL' not found in local directory"
  exit 1
fi

echo "Model '$MODEL' removed"


