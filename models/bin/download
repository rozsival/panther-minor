#!/usr/bin/env bash
# -- Download a model from Hugging Face ---------------------------------------
set -euo pipefail
source "$(dirname "$0")/common.sh"

MODEL=${1:-}

if [[ -z "$MODEL" ]]; then
  echo "Usage: $0 <model-name>"
  exit 1
fi

assert_supported_model "$MODEL"

# Load .env file to get the Hugging Face API token
ENV_FILE="$MODELS_DIR/../.env"

if [[ -f "$ENV_FILE" ]]; then
  export "$(grep -v '^#' "$ENV_FILE" | xargs)"
else
  echo "Warning: .env file not found"
fi

# Extract the model object form `models` array in `config.json` file
MODEL_CONFIG=$(jq -r --arg MODEL "$MODEL" '.models[] | select(.name == $MODEL)' "$CONFIG_FILE")

if [[ -z "$MODEL_CONFIG" ]]; then
  echo "Error: Model '$MODEL' not found in 'config.json'"
  exit 1
fi

# Extract the repository and file information from the model configuration
HF_REPOSITORY=$(jq -r '.repository' <<< "$MODEL_CONFIG")
HF_FILE=$(jq -r '.file' <<< "$MODEL_CONFIG")
MODEL_NAME=$(jq -r '.name' <<< "$MODEL_CONFIG")

# If model file already exists, prompt the user to confirm overwriting it
if [[ -f "$HF_DIR/$MODEL_NAME.gguf" ]]; then
  read -p "Model '$MODEL_NAME' already exists. Do you want to overwrite it? (y/n) " -n 1 -r
  echo

  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Aborting download"
    exit 0
  fi
fi

# Use hf CLI to download the model files
hf download "$HF_REPOSITORY" "$HF_FILE" --local-dir "$HF_DIR"
# Rename the downloaded file to the model name (with overwrite if it already exists)
mv -f "$HF_DIR/$HF_FILE" "$HF_DIR/$MODEL_NAME.gguf"
echo "Model '$MODEL_NAME' ready for use"
