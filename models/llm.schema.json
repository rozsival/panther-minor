{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Configuration schema for models",
  "properties": {
    "models": {
      "description": "List of models",
      "items": {
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Name of the model",
            "type": "string"
          },
          "repository": {
            "description": "Repository containing the model",
            "type": "string"
          },
          "files": {
            "description": "List of model files to download",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": ["name", "repository", "files"],
        "type": "object"
      },
      "type": "array"
    },
    "version": {
      "description": "Configuration version",
      "type": "string"
    }
  },
  "required": ["version", "models"],
  "title": "Models Configuration",
  "type": "object"
}
