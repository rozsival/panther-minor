# ── Model ─────────────────────────────────────────────────────────────────────
# Hugging Face model ID. Qwen3-14B is a safe default for 2×32 GB VRAM.
# To push both GPUs: try Qwen/Qwen3-32B (tight on KV cache) or a GGUF quant.
MODEL=Qwen/Qwen3-14B

# Required only for gated models (Llama, Gemma, etc.). Leave blank for Qwen3.
HF_TOKEN=

# ── Ports ─────────────────────────────────────────────────────────────────────
VLLM_PORT=8000
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
GPU_EXPORTER_PORT=5000
