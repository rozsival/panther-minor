#!/bin/bash
# -- Nginx Proxy SSL Renewal Cron Job Setup Script ----------------------------
PROXY_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROXY_DIR="$(cd "$PROXY_BIN_DIR/.." && pwd)"
SCRIPT_PATH="$PROXY_BIN_DIR/renew-ssl"
TARGET_USER="${SUDO_USER:-$USER}"
LOG_PATH="$PROXY_DIR/renew-ssl.log"
SCHEDULE="0 2 * * *"
CRON_LINE="$SCHEDULE $SCRIPT_PATH >> $LOG_PATH 2>&1"

if [ ! -f "$SCRIPT_PATH" ]; then
	echo "Error: Execution script $SCRIPT_PATH not found."
	exit 1
fi

echo "[info] Configuring SSL renewal cron for user '$TARGET_USER'"
echo "[info] Schedule: $SCHEDULE"
echo "[info] Script: $SCRIPT_PATH"
echo "[info] Log: $LOG_PATH"

if [ "$(id -u)" -eq 0 ]; then
	CRONTAB_LIST_CMD=(crontab -u "$TARGET_USER" -l)
	CRONTAB_INSTALL_CMD=(crontab -u "$TARGET_USER" -)
else
	CRONTAB_LIST_CMD=(crontab -l)
	CRONTAB_INSTALL_CMD=(crontab -)
fi

if "${CRONTAB_LIST_CMD[@]}" 2>/dev/null | grep -Fq "$SCRIPT_PATH"; then
	echo "[ok] Cron job already exists for user '$TARGET_USER'. No changes made."
	exit 0
fi

if ("${CRONTAB_LIST_CMD[@]}" 2>/dev/null; echo "$CRON_LINE") | "${CRONTAB_INSTALL_CMD[@]}"; then
	echo "[ok] Cron job added for user '$TARGET_USER'."
else
	echo "Error: Failed to install cron job for user '$TARGET_USER'."
	exit 1
fi

if "${CRONTAB_LIST_CMD[@]}" 2>/dev/null | grep -Fq "$SCRIPT_PATH"; then
	echo "[ok] Verified cron entry: $CRON_LINE"
else
	echo "Error: Cron installation could not be verified."
	exit 1
fi
