#!/bin/bash
# -- Certbot renew script for Dockerized Nginx reverse proxy ------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROXY_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROJECT_DIR="$(cd "$PROXY_DIR/.." && pwd)"
CURRENT_UID="$(id -u)"
CURRENT_GID="$(id -g)"
CURRENT_OWNER="$CURRENT_UID:$CURRENT_GID"

# Ensure host paths exist before bind-mounting so Docker does not create root-owned dirs.
mkdir -p "$PROXY_DIR/acme" "$PROXY_DIR/ssl"

docker run --rm \
  --user "$CURRENT_OWNER" \
  -v "$PROXY_DIR/acme:/acme.sh" \
  -v "$PROXY_DIR/ssl:/ssl" \
  neilpang/acme.sh --cron

cd "$PROJECT_DIR" || exit 1
docker compose exec proxy nginx -s reload
