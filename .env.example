# -- Model --------------------------------------------------------------------
# Model name and local Modelfile directory name under ./models
# Available: panther-minor, panther-coder-small, panther-coder, panther-coder-large
MODEL=panther-minor
# Number of max models to keep in memory
MODEL_MAX_COUNT=1
# Enforce spreading models across all available GPUs
MODEL_SCHED_SPREAD=true

# -- ROCm ---------------------------------------------------------------------
ROCM_VERSION=v7
ROCM_GFX_VERSION=12.0.1
ROCM_VISIBLE_DEVICES=0,1

# -- Group settings -----------------------------------------------------------
VIDEO_GID=44
RENDER_GID=992
