# -- llama.cpp ----------------------------------------------------------------
LLAMA_CPP_REPO=https://github.com/ggml-org/llama.cpp
LLAMA_CPP_REF=master
LLAMA_CPP_BATCH_SIZE=4096
LLAMA_CPP_MODELS_MAX=3
LLAMA_CPP_SLEEP_IDLE_SECONDS=900
LLAMA_CPP_SLOTS_SIZE=16G
LLAMA_CPP_UBATCH_SIZE=1024

# -- stable-diffusion.cpp -----------------------------------------------------
SD_CPP_REPO=https://github.com/leejet/stable-diffusion.cpp
SD_CPP_REF=master
SD_CPP_SLEEP_IDLE_SECONDS=900

# Active text-to-image model and its component files, given as <repository>/<file>
# paths inside the shared Hugging Face cache. Managed by
# `./bin/cli models t2i load <model>` — sd-server loads exactly one model, so
# only one is ever resident. Leave a component empty when the model omits it
# (e.g. Qwen-Image has no unconditional diffusion model).
SD_CPP_MODEL=Ideogram-4
SD_CPP_DIFFUSION_MODEL=leejet/ideogram-4-GGUF/ideogram4-Q4_0.gguf
SD_CPP_UNCOND_DIFFUSION_MODEL=leejet/ideogram-4-GGUF/ideogram4_uncond-Q4_0.gguf
SD_CPP_LLM=unsloth/Qwen3-VL-8B-Instruct-GGUF/Qwen3-VL-8B-Instruct-UD-Q4_K_XL.gguf
SD_CPP_VAE=Comfy-Org/flux2-dev/split_files/vae/flux2-vae.safetensors
SD_CPP_MODEL_ARGS=
# GPU(s) dedicated to image generation, pinned away from the LLMs to avoid VRAM contention
SD_VISIBLE_DEVICES=1

# -- ROCm ---------------------------------------------------------------------
ROCM_ARCH=gfx1201
ROCM_VISIBLE_DEVICES=0,1

# -- Permission settings ------------------------------------------------------
HOST_UID=1000
HOST_GID=1000
VIDEO_GID=44
RENDER_GID=992

# -- Hugging Face -------------------------------------------------------------
HF_TOKEN=
