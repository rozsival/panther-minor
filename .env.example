# -- Model --------------------------------------------------------------------
# https://ollama.com/search/
MODEL=qwen3-coder:30b-a3b-q8_0
# https://docs.ollama.com/context-length
MODEL_CONTEXT_SIZE=262144
# Number of max models to keep in memory
MODEL_MAX_COUNT=1
# Enforce spreading models across all available GPUs
MODEL_SCHED_SPREAD=true


# -- ROCm ---------------------------------------------------------------------
ROCM_VERSION=v7
ROCM_GFX_VERSION=12.0.1
ROCM_VISIBLE_DEVICES=0,1

# -- Ports --------------------------------------------------------------------
OLLAMA_PORT=8000
OPEN_WEBUI_PORT=8080
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
GPU_EXPORTER_PORT=5000

# -- Group settings -----------------------------------------------------------
VIDEO_GID=44
RENDER_GID=992
