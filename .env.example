# -- llama.cpp ----------------------------------------------------------------
LLAMA_CPP_REPO=https://github.com/TheTom/llama-cpp-turboquant
LLAMA_CPP_REF=feature/turboquant-kv-cache
LLAMA_CPP_BATCH_SIZE=4096
LLAMA_CPP_MODELS_MAX=3
LLAMA_CPP_SLEEP_IDLE_SECONDS=900
LLAMA_CPP_SLOTS_SIZE=16G
LLAMA_CPP_UBATCH_SIZE=1024

# -- ROCm ---------------------------------------------------------------------
ROCM_ARCH=gfx1201
ROCM_VISIBLE_DEVICES=0,1

# -- Permission settings ------------------------------------------------------
HOST_UID=1000
HOST_GID=1000
VIDEO_GID=44
RENDER_GID=992

# -- Hugging Face -------------------------------------------------------------
HF_TOKEN=
