# Set to any Hugging Face model ID.
# 14B is recommended for stability on 2x32GB to leave VRAM for KV cache.
MODEL=Qwen/Qwen2.5-Coder-14B-Instruct

# Max context length.
MAX_MODEL_LEN=32768

# Number of GPUs to use for this model (must match number of indices in HIP_VISIBLE_DEVICES).
TENSOR_PARALLEL_SIZE=2

# Comma-separated list of GPU indices to expose to vLLM (0-indexed).
# Run `sudo bash setup.sh` to see your "ROCm Device Topology".
# 0,1 usually maps to your Radeon AI PRO cards. Index 2 is often the iGPU.
HIP_VISIBLE_DEVICES=0,1

# Required only for gated models (e.g. Llama). Leave blank for Qwen.
HF_TOKEN=

# -- Ports --------------------------------------------------------------------
VLLM_PORT=8000
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
GPU_EXPORTER_PORT=5000
