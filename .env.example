# -- llama.cpp ----------------------------------------------------------------
LLAMA_CPP_REPO=https://github.com/ggml-org/llama.cpp
LLAMA_CPP_REF=master
LLAMA_CPP_BATCH_SIZE=4096
LLAMA_CPP_MODELS_MAX=3
LLAMA_CPP_SLEEP_IDLE_SECONDS=900
LLAMA_CPP_SLOTS_SIZE=16G
LLAMA_CPP_UBATCH_SIZE=1024

# -- stable-diffusion.cpp -----------------------------------------------------
SD_CPP_REPO=https://github.com/leejet/stable-diffusion.cpp
SD_CPP_REF=master
SD_CPP_SLEEP_IDLE_SECONDS=900

# -- ROCm ---------------------------------------------------------------------
ROCM_ARCH=gfx1201
ROCM_VISIBLE_DEVICES=0,1
# GPU(s) dedicated to image generation, pinned away from the LLMs to avoid VRAM contention
SD_VISIBLE_DEVICES=1

# -- Permission settings ------------------------------------------------------
HOST_UID=1000
HOST_GID=1000
VIDEO_GID=44
RENDER_GID=992

# -- Hugging Face -------------------------------------------------------------
HF_TOKEN=
