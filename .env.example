# -- Model --------------------------------------------------------------------
# Set to any Hugging Face model ID, then copy this file to .env and start.
#
# General-purpose (chat, reasoning):
#   Qwen/Qwen3-14B         — default, safe for 2×32 GB, good balance
#   Qwen/Qwen3-32B         — fills most VRAM, top-tier quality
#
# Coding-focused:
#   Qwen/Qwen2.5-Coder-32B-Instruct  — best coder, recommended for dev use
#   Qwen/Qwen2.5-Coder-14B-Instruct  — faster, still excellent for code
#   Qwen/Qwen2.5-Coder-7B-Instruct   — lightweight option
#
# Required only for gated models (Llama, Gemma, etc.). Leave blank for Qwen.
MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# Max context length. Reduce if the model doesn't support 32K or to free VRAM for KV cache.
MAX_MODEL_LEN=32768
# Comma-separated list of GPU indices to expose to vLLM (0-indexed).
HIP_VISIBLE_DEVICES=0,1
HF_TOKEN=

# -- Ports --------------------------------------------------------------------
VLLM_PORT=8000
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
GPU_EXPORTER_PORT=5000
