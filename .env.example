# -- llama.cpp ----------------------------------------------------------------
LLAMA_CPP_REPO=https://github.com/ggml-org/llama.cpp
LLAMA_CPP_REF=master
LLAMA_CPP_SLOTS_SIZE=16G

# -- ROCm ---------------------------------------------------------------------
ROCM_ARCH=gfx1201
ROCM_VISIBLE_DEVICES=0,1

# -- Group settings -----------------------------------------------------------
VIDEO_GID=44
RENDER_GID=992

# -- Hugging Face -------------------------------------------------------------
HF_TOKEN=

# -- OpenFang -----------------------------------------------------------------
OPENFANG_IMAGE=ghcr.io/rightnow-ai/openfang:latest
OPENFANG_HOME=~/.openfang
