# :command.usage
cli_cluster_usage() {
  printf "cli cluster - Manage the Panther Minor Docker Compose cluster\n\n"

  printf "%s\n" "Usage:"
  printf "  cli cluster COMMAND\n"
  printf "  cli cluster [COMMAND] --help | -h\n"
  echo
  # :command.usage_commands
  printf "%s\n" "Commands:"
  printf "  %s   Start the cluster\n" "start  "
  printf "  %s   Show the status of cluster containers\n" "status "
  printf "  %s   Stop the cluster\n" "stop   "
  printf "  %s   Remove cluster containers, volumes, images, and orphans\n" "cleanup"
  printf "  %s   Restart the cluster\n" "restart"
  printf "  %s   Build cluster images\n" "build  "
  echo

  # :command.long_usage
  if [[ -n "$long_usage" ]]; then
    # :command.usage_options
    printf "%s\n" "Options:"

    # :command.usage_fixed_flags
    printf "  %s\n" "--help, -h"
    printf "    Show this help\n"
    echo

  fi
}

# :command.usage
cli_cluster_start_usage() {
  printf "cli cluster start - Start the cluster\n\n"

  printf "%s\n" "Usage:"
  printf "  cli cluster start [SERVICE...] [OPTIONS]\n"
  printf "  cli cluster start --help | -h\n"
  echo

  # :command.long_usage
  if [[ -n "$long_usage" ]]; then
    # :command.usage_options
    printf "%s\n" "Options:"

    # :command.usage_flags
    # :flag.usage
    printf "  %s\n" "--remove-orphans, -r"
    printf "    Remove containers for services not defined in the current configuration\n"
    echo

    # :command.usage_fixed_flags
    printf "  %s\n" "--help, -h"
    printf "    Show this help\n"
    echo

    # :command.usage_args
    printf "%s\n" "Arguments:"

    # :argument.usage
    printf "  %s\n" "SERVICE..."
    printf "    Start only specific service(s); repeat the flag to pass multiple services\n"
    echo

  fi
}

