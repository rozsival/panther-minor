# :command.parse_requirements
cli_cluster_parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        cli_cluster_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action=${1:-}

  case $action in
    -*) ;;

    start)
      action="start"
      shift
      cli_cluster_start_parse_requirements "$@"
      shift $#
      ;;

    status)
      action="status"
      shift
      cli_cluster_status_parse_requirements "$@"
      shift $#
      ;;

    stop)
      action="stop"
      shift
      cli_cluster_stop_parse_requirements "$@"
      shift $#
      ;;

    cleanup)
      action="cleanup"
      shift
      cli_cluster_cleanup_parse_requirements "$@"
      shift $#
      ;;

    restart)
      action="restart"
      shift
      cli_cluster_restart_parse_requirements "$@"
      shift $#
      ;;

    build)
      action="build"
      shift
      cli_cluster_build_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    "")
      cli_cluster_usage >&2
      exit 1
      ;;

    *)
      printf "invalid command: %s\n" "$action" >&2
      exit 1
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

# :command.parse_requirements
cli_cluster_start_parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        cli_cluster_start_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action="cluster start"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      # :flag.case
      --remove-orphans | -r)

        # :flag.case_no_arg
        args['--remove-orphans']=1
        shift
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_repeatable
        # :argument.case_repeatable
        escaped="$(printf '%q' "$1")"
        if [[ -z ${args['service']+x} ]]; then
          args['service']="$escaped"
        else
          args['service']="${args['service']} $escaped"

        fi
        shift

        ;;

    esac
  done

  # :command.validations
  # :argument.validations
  if [[ -v args['service'] ]]; then
    values=''
    eval "values=(${args['service']})"
    for value in "${values[@]}"; do
      validation_output="$(validate_cluster_service "$value")"
      if [[ -n "$validation_output" ]]; then
        printf "validation error in %s:\n%s\n" "SERVICE" "$validation_output" >&2
        exit 1
      fi
    done
  fi

}

