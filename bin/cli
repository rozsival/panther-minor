# :command.usage
cli_usage() {
  printf "cli - 🐆 Panther Minor CLI\n\n"

  printf "%s\n" "Usage:"
  printf "  cli COMMAND\n"
  printf "  cli [COMMAND] --help | -h\n"
  printf "  cli --version | -v\n"
  echo
  # :command.usage_commands
  printf "%s\n" "Commands:"
  printf "  %s   Configure the Panther Minor host\n" "setup      "
  printf "  %s   Manage Panther Minor model files\n" "models     "
  printf "  %s   Manage proxy SSL and certificate automation\n" "proxy      "
  printf "  %s   Manage the Panther Minor Docker Compose cluster\n" "cluster    "
  printf "  %s   Stream logs by default or show a one-time tail for cluster services\n" "logs       "
  printf "  %s   Update the repository from upstream\n" "update     "
  printf "  %s   Print the bash completion script for eval\n" "completions"
  echo

  # :command.long_usage
  if [[ -n "$long_usage" ]]; then
    # :command.usage_options
    printf "%s\n" "Options:"

    # :command.usage_fixed_flags
    printf "  %s\n" "--help, -h"
    printf "    Show this help\n"
    echo
    printf "  %s\n" "--version, -v"
    printf "    Show version number\n"
    echo

  fi
}

