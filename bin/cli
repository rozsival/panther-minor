# :command.parse_requirements
parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        cli_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action=${1:-}

  case $action in
    -*) ;;

    setup)
      action="setup"
      shift
      cli_setup_parse_requirements "$@"
      shift $#
      ;;

    models)
      action="models"
      shift
      cli_models_parse_requirements "$@"
      shift $#
      ;;

    proxy)
      action="proxy"
      shift
      cli_proxy_parse_requirements "$@"
      shift $#
      ;;

    cluster)
      action="cluster"
      shift
      cli_cluster_parse_requirements "$@"
      shift $#
      ;;

    logs)
      action="logs"
      shift
      cli_logs_parse_requirements "$@"
      shift $#
      ;;

    update)
      action="update"
      shift
      cli_update_parse_requirements "$@"
      shift $#
      ;;

    completions)
      action="completions"
      shift
      cli_completions_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    "")
      cli_usage >&2
      exit 1
      ;;

    *)
      printf "invalid command: %s\n" "$action" >&2
      exit 1
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

# :command.parse_requirements
cli_setup_parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        cli_setup_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action=${1:-}

  case $action in

    all)
      action="all"
      shift
      cli_setup_all_parse_requirements "$@"
      shift $#
      ;;

    init)
      action="init"
      shift
      cli_setup_init_parse_requirements "$@"
      shift $#
      ;;

    packages)
      action="packages"
      shift
      cli_setup_packages_parse_requirements "$@"
      shift $#
      ;;

    brew)
      action="brew"
      shift
      cli_setup_brew_parse_requirements "$@"
      shift $#
      ;;

    docker)
      action="docker"
      shift
      cli_setup_docker_parse_requirements "$@"
      shift $#
      ;;

    tailscale)
      action="tailscale"
      shift
      cli_setup_tailscale_parse_requirements "$@"
      shift $#
      ;;

    ssh)
      action="ssh"
      shift
      cli_setup_ssh_parse_requirements "$@"
      shift $#
      ;;

    ufw)
      action="ufw"
      shift
      cli_setup_ufw_parse_requirements "$@"
      shift $#
      ;;

    fail2ban)
      action="fail2ban"
      shift
      cli_setup_fail2ban_parse_requirements "$@"
      shift $#
      ;;

    amdgpu)
      action="amdgpu"
      shift
      cli_setup_amdgpu_parse_requirements "$@"
      shift $#
      ;;

    grub)
      action="grub"
      shift
      cli_setup_grub_parse_requirements "$@"
      shift $#
      ;;

    git)
      action="git"
      shift
      cli_setup_git_parse_requirements "$@"
      shift $#
      ;;

    shell)
      action="shell"
      shift
      cli_setup_shell_parse_requirements "$@"
      shift $#
      ;;

    env)
      action="env"
      shift
      cli_setup_env_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    *)
      action="all"
      cli_setup_all_parse_requirements "$@"
      shift $#
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

# :command.parse_requirements
cli_setup_all_parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        cli_setup_all_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.environment_variables_filter

  env_var_names+=("PANTHER_SERVER_NAME")
  env_var_names+=("PANTHER_ALLOWED_USER")
  env_var_names+=("PANTHER_SSH_PORT")
  env_var_names+=("PANTHER_TIMEZONE")
  env_var_names+=("PANTHER_LVM_DEVICE")
  # :environment_variable.validations
  if [[ -v PANTHER_SSH_PORT ]]; then
    validation_output="$(validate_port "$PANTHER_SSH_PORT")"
    if [[ -n "${validation_output}" ]]; then
      printf "validation error in environment variable %s:\n%s\n" "PANTHER_SSH_PORT" "$validation_output" >&2
      exit 1
    fi
  fi

  # :command.command_filter
  action="setup all"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      # :flag.case
      --server-name | -n)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--server-name']="$2"
          shift
          shift
        else
          printf "%s\n" "--server-name requires an argument: --server-name, -n NAME" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --allowed-user | -u)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--allowed-user']="$2"
          shift
          shift
        else
          printf "%s\n" "--allowed-user requires an argument: --allowed-user, -u USER" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --ssh-port | -p)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--ssh-port']="$2"
          shift
          shift
        else
          printf "%s\n" "--ssh-port requires an argument: --ssh-port, -p PORT" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --timezone | -t)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--timezone']="$2"
          shift
          shift
        else
          printf "%s\n" "--timezone requires an argument: --timezone, -t TIMEZONE" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --lvm-device | -d)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--lvm-device']="$2"
          shift
          shift
        else
          printf "%s\n" "--lvm-device requires an argument: --lvm-device, -d PATH" >&2
          exit 1
        fi
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

  # :command.validations
  # :flag.validations
  if [[ -v args['--ssh-port'] ]]; then
    validation_output="$(validate_port "${args['--ssh-port']:-}")"
    if [[ -n "${validation_output}" ]]; then
      printf "validation error in %s:\n%s\n" "--ssh-port, -p PORT" "$validation_output" >&2
      exit 1
    fi
  fi

}

